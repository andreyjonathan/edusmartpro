{
    "version": 2,
    "cleanUrls": true,
    "trailingSlash": false,
    "functions": {
        "index.php": {
            "runtime": "vercel-php@0.7.3"
        }
    },
    "routes": [
        {
            "handle": "filesystem"
        },
        {
            "src": "/(.*)",
            "dest": "/index.php"
        }
    ]
}
