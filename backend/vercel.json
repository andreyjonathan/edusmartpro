{
    "version": 2,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.3",
            "excludeFiles": "{node_modules/**,tests/**,resources/js/**,resources/css/**}"
        }
    },
    "routes": [
        {
            "src": "/(build|favicon.ico|robots.txt)(.*)",
            "dest": "/$1$2"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_KEY":"base64:o0leHGbXDtGxI4vLndwIMKJPWWF+fH7pq1hSHKuDQ6c=",
        "APP_ENV": "production",
        "APP_DEBUG": "true",
        "APP_URL": "https://edusmartpro.vercel.app",
        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "VIEW_COMPILED_PATH": "/tmp",
        "CACHE_DRIVER": "array",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie"
    },
    "outputDirectory": "public"
}
